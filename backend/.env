
APP_NAME=FastAPI RAG System
APP_VERSION=1.0.0
DEBUG=true
API_V1_PREFIX=/api/v1

SECRET_KEY=please-change-this-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

DATABASE_URL=postgresql+asyncpg://postgres:Qq124094@127.0.0.1:5432/rag_db
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000"]
UPLOAD_DIR=./uploads

LOG_LEVEL=INFO
ACCESS_LOG_ENABLED=true

DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=Admin@123456
DEFAULT_ADMIN_FULL_NAME=Platform Admin

CHAT_HISTORY_MAX_TURNS=50

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5
MIN_SIMILARITY_SCORE=0.1
RAG_CLEAN_REMOVE_LINKS=true
RAG_MIN_SEGMENT_LEN=8
MAX_FILE_SIZE_MB=100
KEEP_UPLOADED_FILES=false
PRELOAD_EMBEDDING_MODEL=true

