APP_NAME=FastAPI Multi Tenant System
APP_VERSION=1.0.0
DEBUG=true
API_V1_PREFIX=/api/v1

SECRET_KEY=please-change-this-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

DATABASE_URL=postgresql+psycopg://postgres:Qq124094@localhost:5432/rag_service
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000"]
UPLOAD_DIR=./uploads

# 日志配置
# LOG_LEVEL=INFO          # 日志级别: DEBUG, INFO, WARNING, ERROR
# ACCESS_LOG_ENABLED=true # 是否启用访问日志
LOG_LEVEL=INFO
ACCESS_LOG_ENABLED=true

DEFAULT_TENANT_NAME=Platform Tenant
DEFAULT_TENANT_CODE=platform
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=Admin@123456
DEFAULT_ADMIN_FULL_NAME=Platform Admin

# RAG 配置
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=rag_documents
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_MODEL_DEVICE=cpu
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_FILE_SIZE_MB=100
TOP_K_RETRIEVAL=5
BM25_ENABLED=true
BM25_K1=1.5
BM25_B=0.75

# DeepSeek LLM 配置
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=sk-5c3651a66c2e41bcbd435f959739bdc9
LLM_MODEL_NAME=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Redis 配置 (聊天记忆)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL_SECONDS=86400

# 聊天历史配置
CHAT_HISTORY_MAX_TURNS=50
