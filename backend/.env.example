# ========================================
# FastAPI RAG 系统 - 环境配置模板
# ========================================
# 复制此文件为 .env 并根据您的环境进行修改
# ========================================

# ========================================
# 基本应用配置
# ========================================
APP_NAME=FastAPI Multi Tenant System
APP_VERSION=1.0.0
DEBUG=false
API_V1_PREFIX=/api/v1

# ========================================
# 安全配置 - 生产环境必须修改！
# ========================================
# 使用强随机字符串作为SECRET_KEY，例如可以使用: openssl rand -hex 32
SECRET_KEY=change-me-to-a-strong-random-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ========================================
# 数据库配置
# ========================================
# PostgreSQL 连接字符串格式: postgresql+psycopg://user:password@host:port/database
DATABASE_URL=postgresql+psycopg://postgres:your-secure-password@localhost:5432/rag_service

# ========================================
# CORS 配置 - 生产环境只允许特定域名！
# ========================================
CORS_ORIGINS=["https://your-production-domain.com","https://www.your-production-domain.com"]
UPLOAD_DIR=./uploads

# ========================================
# 日志配置
# ========================================
LOG_LEVEL=INFO
ACCESS_LOG_ENABLED=true
LOG_DIR=./logs

# ========================================
# 默认租户和管理员配置
# ========================================
DEFAULT_TENANT_NAME=Platform Tenant
DEFAULT_TENANT_CODE=platform
DEFAULT_ADMIN_EMAIL=admin@your-domain.com
DEFAULT_ADMIN_PASSWORD=ChangeThisPassword123!
DEFAULT_ADMIN_FULL_NAME=Platform Admin

# ========================================
# RAG 配置
# ========================================
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=rag_documents
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_MODEL_DEVICE=cpu
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_FILE_SIZE_MB=100
TOP_K_RETRIEVAL=5
BM25_ENABLED=true
BM25_K1=1.5
BM25_B=0.75

# ========================================
# DeepSeek LLM 配置 - 生产环境必须配置有效的API Key！
# ========================================
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=your-deepseek-api-key-here
LLM_MODEL_NAME=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# ========================================
# Redis 配置 - 生产环境必须设置密码！
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-redis-password-here
REDIS_TTL_SECONDS=86400

# ========================================
# 聊天历史配置
# ========================================
CHAT_HISTORY_MAX_TURNS=50
