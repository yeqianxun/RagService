# ========================================
# FastAPI RAG 系统 - 环境配置模板
# ========================================
# 复制此文件为 .env 并根据您的环境进行修改
# ========================================

# ========================================
# 基本应用配置
# ========================================
APP_NAME=FastAPI RAG System
APP_VERSION=1.0.0
DEBUG=false
API_V1_PREFIX=/api/v1

# ========================================
# 安全配置 - 生产环境必须修改！
# ========================================
# 使用强随机字符串作为 SECRET_KEY，例如可以使用: openssl rand -hex 32
SECRET_KEY=change-me-to-a-strong-random-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ========================================
# PostgreSQL 数据库配置
# ========================================
DATABASE_URL=postgresql+asyncpg://postgres:your-secure-password@localhost:5432/rag_db

# ========================================
# CORS 配置 - 生产环境只允许特定域名！
# ========================================
CORS_ORIGINS=["https://your-production-domain.com","https://www.your-production-domain.com"]
UPLOAD_DIR=./uploads

# ========================================
# 日志配置
# ========================================
LOG_LEVEL=INFO
ACCESS_LOG_ENABLED=true
LOG_DIR=./logs

# ========================================
# 默认管理员配置
# ========================================
DEFAULT_ADMIN_EMAIL=admin@your-domain.com
DEFAULT_ADMIN_PASSWORD=ChangeThisPassword123!
DEFAULT_ADMIN_FULL_NAME=Platform Admin

# ========================================
# RAG 配置
# ========================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_FILE_SIZE_MB=100
TOP_K_RETRIEVAL=5
MIN_SIMILARITY_SCORE=0.1
RAG_CLEAN_REMOVE_LINKS=true
RAG_MIN_SEGMENT_LEN=8
KEEP_UPLOADED_FILES=false
PRELOAD_EMBEDDING_MODEL=true

# ========================================
# DeepSeek LLM 配置 - 生产环境必须配置有效的 API Key！
# ========================================
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=your-deepseek-api-key-here
LLM_MODEL_NAME=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# ========================================
# Redis 配置 - 生产环境必须设置密码！
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-redis-password-here
REDIS_TTL_SECONDS=86400

# ========================================
# 聊天历史配置
# ========================================
CHAT_HISTORY_MAX_TURNS=50
